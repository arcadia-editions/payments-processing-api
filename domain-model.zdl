config {
    id "urn:com.arcadiaeditions:payments:processing"
    title "Arcadia Editions - Payments Processing"
    basePackage "com.arcadiaeditions.payments.processing"
    persistence jpa

    plugins {
        /** Generates an AsyncAPI v3 specification from this ZDL model. */
        ZDLToAsyncAPIPlugin {
            id "urn:com.arcadiaeditions:payments:processing:asyncapi"
            schemaFormat avro
            idType integer
            idTypeFormat int64
            avroPackage com.arcadiaeditions.payments.processing.events.avro
            includeCloudEventsHeaders true
            includeKafkaCommonHeaders true
            targetFile "./asyncapi.yml"
        }
        ZDLToAsyncAPIClientPlugin {
            id "urn:com.arcadiaeditions:payments:processing:asyncapi:client"
            title "Arcadia Editions - Payments Processing - AsyncAPI Client"
            targetFile "./asyncapi-client.yml"
        }
        /** Generates an OpenAPI 3.0 specification from this ZDL model. */
        ZDLToOpenAPIPlugin {
            idType integer
            idTypeFormat int64
            targetFile "./openapi.yml"
        }
    }
}

apis {
    asyncapi client OrdersCheckoutApi "https://raw.githubusercontent.com/arcadia-editions/orders-checkout-api/main/asyncapi.yml"
    asyncapi client FulfillmentShippingApi "https://raw.githubusercontent.com/arcadia-editions/fulfillment-shipping-api/main/asyncapi.yml"
}

@aggregate
@lifecycle(field: status, initial: AUTHORIZATION_REQUESTED)
entity Payment {
    paymentId String required unique
    orderId String required unique
    customerId String required
    amount BigDecimal required
    currency String required
    status PaymentStatus required
    providerReference String
    attemptCount Integer required
    authorizedAt Instant
    declinedAt Instant
    failedAt Instant
    capturedAt Instant
    voidedAt Instant
    failureReason String
}

enum PaymentStatus {
    AUTHORIZATION_REQUESTED
    AUTHORIZED
    DECLINED
    FAILED
    RETRY_EXHAUSTED
    CAPTURED
    VOIDED
}

input AuthorizePaymentInput {
    orderId String required
    customerId String required
    amount BigDecimal required
    currency String required
    paymentMethodId String required
}

input RetryPaymentInput {
    paymentId String required
    orderId String required
}

input CapturePaymentInput {
    paymentId String required
    orderId String required
}

input VoidPaymentInput {
    paymentId String required
    orderId String required
    reason String required
}

@rest("/payments")
service PaymentsProcessingService for (Payment) {

    @asyncapi(api: OrdersCheckoutApi, channel: "order-created-event-v1")
    @transition(to: AUTHORIZATION_REQUESTED)
    authorizePayment(AuthorizePaymentInput) Payment withEvents PaymentAuthorized PaymentDeclined PaymentFailed

    @asyncapi(channel: "payment-failed-event-v1")
    @transition(from: FAILED, to: AUTHORIZATION_REQUESTED)
    retryPayment(RetryPaymentInput) Payment withEvents PaymentRetried PaymentRetryExhausted

    @asyncapi(api: FulfillmentShippingApi, channel: "fulfillment-scheduled-event-v1")
    @transition(from: AUTHORIZED, to: CAPTURED)
    capturePayment(CapturePaymentInput) Payment withEvents PaymentCaptured PaymentCaptureFailed

    @asyncapi(api: FulfillmentShippingApi, channel: "fulfillment-failed-event-v1")
    @asyncapi(channel: "payment-capture-failed-event-v1")
    @transition(from: [AUTHORIZED, AUTHORIZATION_REQUESTED, FAILED], to: VOIDED)
    voidPayment(VoidPaymentInput) Payment withEvents PaymentVoided
}

@asyncapi({ channel: "payment-authorized-event-v1", topic: "payments-processing.payment-authorized.event.avro.v1" })
event PaymentAuthorized {
    paymentId String
    orderId String
    customerId String
    amount BigDecimal
    currency String
    providerReference String
    authorizedAt Instant
}

@asyncapi({ channel: "payment-declined-event-v1", topic: "payments-processing.payment-declined.event.avro.v1" })
event PaymentDeclined {
    paymentId String
    orderId String
    customerId String
    amount BigDecimal
    currency String
    reason String
    declinedAt Instant
}

@asyncapi({ channel: "payment-failed-event-v1", topic: "payments-processing.payment-failed.event.avro.v1" })
event PaymentFailed {
    paymentId String
    orderId String
    customerId String
    attemptCount Integer
    reason String
    failedAt Instant
}

@asyncapi({ channel: "payment-retried-event-v1", topic: "payments-processing.payment-retried.event.avro.v1" })
event PaymentRetried {
    paymentId String
    orderId String
    customerId String
    attemptCount Integer
    retriedAt Instant
}

@asyncapi({ channel: "payment-retry-exhausted-event-v1", topic: "payments-processing.payment-retry-exhausted.event.avro.v1" })
event PaymentRetryExhausted {
    paymentId String
    orderId String
    customerId String
    attemptCount Integer
    reason String
    exhaustedAt Instant
}

@asyncapi({ channel: "payment-captured-event-v1", topic: "payments-processing.payment-captured.event.avro.v1" })
event PaymentCaptured {
    paymentId String
    orderId String
    customerId String
    amount BigDecimal
    currency String
    providerReference String
    capturedAt Instant
}

@asyncapi({ channel: "payment-capture-failed-event-v1", topic: "payments-processing.payment-capture-failed.event.avro.v1" })
event PaymentCaptureFailed {
    paymentId String
    orderId String
    customerId String
    reason String
    failedAt Instant
}

@asyncapi({ channel: "payment-voided-event-v1", topic: "payments-processing.payment-voided.event.avro.v1" })
event PaymentVoided {
    paymentId String
    orderId String
    customerId String
    providerReference String
    reason String
    voidedAt Instant
}
